{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role details",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth user ID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["Maamulaha", "Injineer", "Akhri-Kaliya"], "description": "Privilege role in Somali or English" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Document": {
      "title": "Document Metadata",
      "description": "Georeferenced engineering drawing or survey document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "string" },
        "date": { "type": "string" },
        "tags": { "type": "array" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploaderName": { "type": "string" },
        "Owner": { "type": "string" },
        "ComplianceCode": { "type": "string" },
        "VersionHistory": { "type": "string" },
        "url": { "type": "string" }
      },
      "required": ["id", "name", "date", "type"]
    },
    "Project": {
      "title": "Land Survey Project Site",
      "description": "Geodetic survey site with progress and location",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "status": { "type": "string" },
        "health": { "type": "string" },
        "progress": { "type": "number" },
        "docRate": { "type": "number" },
        "budget": { "type": "string" },
        "daysRemaining": { "type": "number" },
        "engineer": { "type": "string" },
        "milestones": { "type": "array" },
        "docs": { "type": "number" },
        "date": { "type": "string" },
        "bg": { "type": "string" },
        "color": { "type": "string" },
        "desc": { "type": "string" },
        "coords": { "type": "string" },
        "users": { "type": "number" },
        "pending": { "type": "number" }
      },
      "required": ["id", "name", "location", "lat", "lng"]
    },
    "ActivityLog": {
      "title": "System Activity Logs",
      "description": "Log of actions performed inside the application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "user": { "type": "string" },
        "file": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "type", "user", "time"]
    },
    "WebApp": {
      "title": "Integrated Web Application",
      "description": "Geospatial, mapping, and geodetic web application for Somalia GIS workflows",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description_en": { "type": "string" },
        "description_so": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "createdBy": { "type": "string" },
        "isFavorite": { "type": "boolean" }
      },
      "required": ["id", "name", "url", "category"]
    },
    "ApprovalItem": {
      "title": "Decision Queue Item",
      "description": "Pending sign-offs and workflow approvals for active projects",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "doc": { "type": "string" },
        "project": { "type": "string" },
        "user": { "type": "string" },
        "date": { "type": "string" },
        "urgency": { "type": "string" }
      },
      "required": ["id", "doc", "project", "user", "date", "urgency"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User records for authorization"
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Metadata logs for surveyor uploads"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Active land survey boundaries and sites"
    },
    "/activities/{activityId}": {
      "schema": "ActivityLog",
      "description": "Recent engineering operations"
    },
    "/webapps/{webappId}": {
      "schema": "WebApp",
      "description": "Registered engineering and spatial web applications"
    },
    "/approvals/{approvalId}": {
      "schema": "ApprovalItem",
      "description": "Pending sign-offs and approvals for active projects"
    }
  }
}
